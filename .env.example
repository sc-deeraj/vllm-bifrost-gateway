# Copy to .env and adjust. All values below are the defaults baked into
# docker-compose.yml -- only uncomment/edit what you need to change.

### Base model served by vLLM
# Qwen3.5-9B is multimodal (text + image) and bf16-native. Image input works
# out of the box -- no separate plugin. Requires a current vLLM image (the
# old v0.9.2 pin cannot load it); see VLLM_IMAGE below.
# BASE_MODEL=Qwen/Qwen3.5-9B
# BASE_MODEL_ID=qwen3.5-9b

### vLLM image
# Qwen3.5 needs a recent vLLM. `latest` tracks the newest published image; pin
# a specific tag once verified. If a stable tag lacks Qwen3.5 support, build/
# use a nightly image (https://wheels.vllm.ai/nightly).
# VLLM_IMAGE=vllm/vllm-openai:latest

### Precision  (FP16 | FP8 | FP4)
# FP16 = full 16-bit, no quantization (default). Defaults to bf16 (Qwen-native);
#        set VLLM_DTYPE=float16 to force true fp16.
#        NOTE: ~18GB of weights -- very tight on a 24GB card with vision + KV
#        cache. Use FP8 there, or set VLLM_LANGUAGE_MODEL_ONLY=true / lower
#        VLLM_MAX_MODEL_LEN.
# FP8  = online dynamic FP8 (~9GB). Runs on Ada/Hopper. Recommended for 24GB.
# FP4  = NVFP4. Needs a Blackwell GPU (sm_100+) AND a pre-quantized FP4
#        checkpoint -- will NOT run on RTX 4000 (Ada). Adjust VLLM_FP4_METHOD
#        / BASE_MODEL if you have FP4 hardware + weights.
# VLLM_PRECISION=FP16
# VLLM_DTYPE=                 # e.g. float16 or bfloat16 (overrides the default)
# VLLM_FP4_METHOD=modelopt_fp4

### vLLM tuning (sized for a single 24GB GPU)
# VLLM_MAX_MODEL_LEN=32768           # Qwen3.5-9B native max is 262144 (needs lots of VRAM)
# VLLM_GPU_MEMORY_UTILIZATION=0.90
# VLLM_REASONING_PARSER=qwen3        # Qwen3.5 thinking-mode parser

### Multimodal / vision
# VLLM_MAX_IMAGES_PER_PROMPT=2       # max images accepted per request
# VLLM_LANGUAGE_MODEL_ONLY=false     # true => skip vision encoder, text-only, saves VRAM

### Optional LoRA hot-swap (off by default for the vision path)
# Safe with FP16; LoRA + FP8/FP4 has compatibility edge cases.
# VLLM_ENABLE_LORA=false
# VLLM_MAX_LORAS=2          # max adapters "hot" in a single batch
# VLLM_MAX_LORA_RANK=16     # must be >= the rank of any adapter you load
# VLLM_MAX_CPU_LORAS=4      # max adapters cached in host RAM

### Escape hatch: extra raw flags appended to `vllm serve`
# VLLM_EXTRA_ARGS=

### Only needed for gated models on Hugging Face
# HF_TOKEN=

### Model Manager
# MM_PORT=9000
# MM_ADAPTER_CAPACITY=2                 # keep <= VLLM_MAX_CPU_LORAS
# MM_COLD_START_TIMEOUT_SECONDS=90
# MM_DRAIN_TIMEOUT_SECONDS=30

### Bifrost
# BIFROST_PORT=8080
