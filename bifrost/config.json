{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "enforce_auth_on_inference": true
  },
  "providers": {
    "vllm-openai-compatible": {
      "keys": [
        {
          "name": "vllm-provider-key",
          "value": "sk-vllm-ea999536bb94a724fcfe160bfe185e3967f15e0754684d06",
          "models": ["*"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "http://model-manager:9000",
        "allow_private_network": true
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true,
          "text_completion": true,
          "text_completion_stream": true,
          "embedding": false,
          "list_models": true
        },
        "request_path_overrides": {
          "chat_completion": "/v1/chat/completions",
          "chat_completion_stream": "/v1/chat/completions",
          "text_completion": "/v1/completions",
          "text_completion_stream": "/v1/completions"
        }
      }
    }
  },
